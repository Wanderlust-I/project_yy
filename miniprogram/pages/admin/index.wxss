page {
  background: #f4f7f8;
}

.page {
  min-height: 100vh;
  padding-bottom: calc(42rpx + env(safe-area-inset-bottom));
}

.topbar {
  padding: 38rpx 28rpx 34rpx;
  background: #185c5d;
  color: #ffffff;
  border-bottom-left-radius: 28rpx;
  border-bottom-right-radius: 28rpx;
}

.topbar__meta {
  color: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
  line-height: 34rpx;
}

.topbar__title {
  margin-top: 8rpx;
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 58rpx;
}

.topbar__name {
  margin-top: 22rpx;
  min-height: 48rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 26rpx;
  line-height: 48rpx;
}

.content {
  padding: 26rpx 24rpx 0;
}

.section__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.section__title {
  color: #1f2d2d;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 44rpx;
}

.section__extra {
  color: #8a9899;
  font-size: 24rpx;
  line-height: 34rpx;
}

.module-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.module {
  min-height: 142rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  gap: 18rpx;
  text-align: left;
  box-shadow: 0 10rpx 24rpx rgba(31, 45, 45, 0.06);
  border-left: 8rpx solid #185c5d;
}

.module--amber {
  border-left-color: #b7812d;
}

.module__icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  background: #e6f1ee;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.module--amber .module__icon {
  background: #f8efdf;
}

.module__shape {
  width: 30rpx;
  height: 30rpx;
  border-radius: 8rpx;
  border: 6rpx solid #185c5d;
  box-sizing: border-box;
}

.module--amber .module__shape {
  border-color: #b7812d;
}

.module__body {
  flex: 1;
  min-width: 0;
}

.module__title {
  color: #1f2d2d;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 42rpx;
}

.module__desc {
  margin-top: 8rpx;
  color: #829192;
  font-size: 24rpx;
  line-height: 34rpx;
}

.module__arrow {
  color: #8a9899;
  font-size: 42rpx;
  line-height: 42rpx;
  flex-shrink: 0;
}
