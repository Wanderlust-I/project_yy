page {
  background: #eef4f4;
}

.page {
  min-height: 100vh;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.hero {
  padding: 38rpx 28rpx 40rpx;
  background: #185c5d;
  color: #ffffff;
  border-bottom-left-radius: 34rpx;
  border-bottom-right-radius: 34rpx;
  box-shadow: 0 18rpx 44rpx rgba(24, 92, 93, 0.18);
}

.hero__bar {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.hero__copy {
  min-width: 0;
}

.hero__eyebrow {
  color: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
  line-height: 34rpx;
}

.hero__title {
  margin-top: 8rpx;
  color: #ffffff;
  font-size: 46rpx;
  font-weight: 700;
  line-height: 60rpx;
}

.hero__panel {
  margin-top: 30rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.12);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.hero__panel-label {
  color: rgba(255, 255, 255, 0.68);
  font-size: 23rpx;
  line-height: 32rpx;
}

.hero__panel-title {
  margin-top: 6rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 40rpx;
}

.hero__create {
  width: 112rpx;
  height: 60rpx;
  border-radius: 30rpx;
  background: #ffffff;
  color: #185c5d;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 60rpx;
  text-align: center;
  flex-shrink: 0;
}

.summary {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.summary__item {
  min-height: 116rpx;
  padding: 18rpx 16rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border-left: 6rpx solid #185c5d;
  box-shadow: 0 10rpx 24rpx rgba(20, 64, 65, 0.12);
}

.summary__item--amber {
  border-left-color: #b7812d;
}

.summary__item--coral {
  border-left-color: #c9503f;
}

.summary__label {
  color: #627273;
  font-size: 22rpx;
  line-height: 30rpx;
}

.summary__main {
  margin-top: 12rpx;
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.summary__value {
  color: #1f2d2d;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 50rpx;
}

.summary__unit {
  color: #829192;
  font-size: 22rpx;
  line-height: 30rpx;
}

.content {
  padding: 0 24rpx;
}

.filters {
  margin-top: 24rpx;
  padding: 8rpx;
  border-radius: 18rpx;
  background: #ffffff;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8rpx;
  box-shadow: 0 10rpx 24rpx rgba(31, 45, 45, 0.06);
}

.filter {
  height: 64rpx;
  border-radius: 14rpx;
  color: #607273;
  font-size: 26rpx;
  line-height: 64rpx;
  text-align: center;
}

.filter--active {
  background: #185c5d;
  color: #ffffff;
  font-weight: 700;
}

.section {
  margin-top: 30rpx;
}

.section__head {
  margin-bottom: 20rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
}

.section__title {
  color: #1f2d2d;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 44rpx;
}

.section__subtitle {
  margin-top: 4rpx;
  color: #8a9899;
  font-size: 23rpx;
  line-height: 32rpx;
}

.section__count {
  min-width: 84rpx;
  height: 44rpx;
  border-radius: 22rpx;
  background: #e6f1ee;
  color: #185c5d;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 44rpx;
  text-align: center;
  flex-shrink: 0;
}

.timeline {
  display: flex;
  flex-direction: column;
}

.activity {
  display: flex;
  align-items: stretch;
  gap: 18rpx;
}

.activity__rail {
  width: 86rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.activity__date {
  width: 78rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background: #185c5d;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 48rpx;
  text-align: center;
}

.activity__line {
  width: 4rpx;
  flex: 1;
  min-height: 28rpx;
  margin-top: 10rpx;
  margin-bottom: 10rpx;
  border-radius: 2rpx;
  background: #d7e2e2;
}

.activity:last-child .activity__line {
  background: transparent;
}

.activity__card {
  flex: 1;
  min-width: 0;
  margin-bottom: 20rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(31, 45, 45, 0.07);
}

.activity__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.activity__time {
  color: #185c5d;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 38rpx;
}

.activity__title {
  margin-top: 16rpx;
  color: #1f2d2d;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 42rpx;
}

.activity__company {
  margin-top: 10rpx;
  color: #607273;
  font-size: 25rpx;
  line-height: 36rpx;
}

.status {
  max-width: 156rpx;
  min-height: 46rpx;
  padding: 8rpx 12rpx;
  border-radius: 23rpx;
  font-size: 22rpx;
  line-height: 30rpx;
  text-align: center;
  flex-shrink: 0;
}

.status--pending {
  background: #fff2d7;
  color: #9b6818;
}

.status--active {
  background: #e3f2ee;
  color: #185c5d;
}

.status--ready {
  background: #edf0f2;
  color: #60727b;
}

.info-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: 1fr;
  gap: 12rpx;
}

.info-item {
  padding: 14rpx 16rpx;
  border-radius: 12rpx;
  background: #f7fafb;
  display: flex;
  gap: 14rpx;
}

.info-item__label {
  width: 54rpx;
  color: #8a9899;
  font-size: 23rpx;
  line-height: 32rpx;
  flex-shrink: 0;
}

.info-item__value {
  flex: 1;
  min-width: 0;
  color: #435354;
  font-size: 23rpx;
  line-height: 32rpx;
}

.services {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.service {
  min-height: 42rpx;
  padding: 0 16rpx;
  border-radius: 21rpx;
  background: #edf1f2;
  color: #536364;
  font-size: 22rpx;
  line-height: 42rpx;
}
