<view class="page">
  <view class="hero">
    <view class="hero__bar">
      <view class="hero__copy">
        <view class="hero__eyebrow">{{todayText}}</view>
        <view class="hero__title">接待活动</view>
      </view>
    </view>

    <view class="hero__panel">
      <view>
        <view class="hero__panel-label">今日接待总览</view>
        <view class="hero__panel-title">活动排期与会务状态</view>
      </view>
      <button class="hero__create" bindtap="onTapCreate">新建</button>
    </view>

    <view class="summary">
      <view
        class="summary__item summary__item--{{item.theme}}"
        wx:for="{{summary}}"
        wx:key="label"
      >
        <view class="summary__label">{{item.label}}</view>
        <view class="summary__main">
          <text class="summary__value">{{item.value}}</text>
          <text class="summary__unit">{{item.unit}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="content">
    <view class="filters">
      <button
        class="filter {{item.selected ? 'filter--active' : ''}}"
        wx:for="{{filters}}"
        wx:key="value"
        data-value="{{item.value}}"
        bindtap="onSelectFilter"
      >
        {{item.label}}
      </button>
    </view>

    <view class="section">
      <view class="section__head">
        <view>
          <view class="section__title">活动列表</view>
          <view class="section__subtitle">按接待开始时间排列</view>
        </view>
        <view class="section__count">{{visibleCount}}场</view>
      </view>

      <view class="timeline">
        <view
          class="activity"
          wx:for="{{visibleActivities}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onTapActivity"
        >
          <view class="activity__rail">
            <view class="activity__date">{{item.dateLabel}}</view>
            <view class="activity__line"></view>
          </view>

          <view class="activity__card">
            <view class="activity__header">
              <view class="activity__time">{{item.time}}</view>
              <view class="status status--{{item.statusType}}">{{item.status}}</view>
            </view>

            <view class="activity__title">{{item.title}}</view>
            <view class="activity__company">{{item.company}}</view>

            <view class="info-grid">
              <view class="info-item">
                <text class="info-item__label">地点</text>
                <text class="info-item__value">{{item.place}}</text>
              </view>
              <view class="info-item">
                <text class="info-item__label">接待</text>
                <text class="info-item__value">{{item.host}}</text>
              </view>
              <view class="info-item">
                <text class="info-item__label">人数</text>
                <text class="info-item__value">{{item.visitors}}</text>
              </view>
            </view>

            <view class="services">
              <text
                class="service"
                wx:for="{{item.services}}"
                wx:for-item="service"
                wx:key="*this"
              >
                {{service}}
              </text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
