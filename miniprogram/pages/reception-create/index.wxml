<view class="page">
  <view class="topbar">
    <view class="topbar__meta">{{form.department}} · {{form.applicantName}}</view>
    <view class="topbar__title">新建接待申请</view>
    <view class="topbar__summary">
      <view class="summary-item">
        <text class="summary-item__label">类型</text>
        <text class="summary-item__value">{{form.type}}</text>
      </view>
      <view class="summary-item">
        <text class="summary-item__label">人数</text>
        <text class="summary-item__value">{{form.visitorCount}}人</text>
      </view>
      <view class="summary-item">
        <text class="summary-item__label">需求</text>
        <text class="summary-item__value summary-item__value--wrap">{{selectedServicesText}}</text>
      </view>
    </view>
  </view>

  <view class="form">
    <view class="form-section">
      <view class="form-section__head">
        <view class="form-section__title">基础信息</view>
        <view class="form-section__mark">必填</view>
      </view>

      <view class="field">
        <view class="field__label">接待类型</view>
        <view class="segmented">
          <button
            class="segment {{item.selected ? 'segment--active' : ''}}"
            wx:for="{{typeItems}}"
            wx:key="name"
            data-value="{{item.name}}"
            bindtap="onSelectType"
          >
            {{item.name}}
          </button>
        </view>
      </view>

      <view class="field">
        <view class="field__label">接待主题</view>
        <input
          class="input"
          value="{{form.title}}"
          data-field="title"
          bindinput="onInput"
          placeholder="如：机构客户业务沟通会"
          placeholder-class="input__placeholder"
        />
      </view>

      <view class="field">
        <view class="field__label">来访单位</view>
        <input
          class="input"
          value="{{form.company}}"
          data-field="company"
          bindinput="onInput"
          placeholder="请输入单位或团队名称"
          placeholder-class="input__placeholder"
        />
      </view>
    </view>

    <view class="form-section">
      <view class="form-section__head">
        <view class="form-section__title">来访安排</view>
      </view>

      <view class="field-row">
        <view class="field field--half">
          <view class="field__label">到访日期</view>
          <picker mode="date" value="{{form.visitDate}}" start="{{minDate}}" bindchange="onDateChange">
            <view class="picker">{{form.visitDate}}</view>
          </picker>
        </view>
        <view class="field field--half">
          <view class="field__label">来访人数</view>
          <input
            class="input"
            type="number"
            value="{{form.visitorCount}}"
            data-field="visitorCount"
            bindinput="onInput"
            placeholder="请输入人数"
            placeholder-class="input__placeholder"
            style="text-align: center;"
          />
        </view>
      </view>

      <view class="field-row">
        <view class="field field--half">
          <view class="field__label">开始时间</view>
          <picker mode="time" value="{{form.startTime}}" data-field="startTime" bindchange="onTimeChange">
            <view class="picker">{{form.startTime}}</view>
          </picker>
        </view>
        <view class="field field--half">
          <view class="field__label">结束时间</view>
          <picker mode="time" value="{{form.endTime}}" data-field="endTime" bindchange="onTimeChange">
            <view class="picker">{{form.endTime}}</view>
          </picker>
        </view>
      </view>

      <view class="field">
        <view class="field__label">接待地点</view>
        <picker value="{{placeIndex}}" range="{{placeOptions}}" bindchange="onPlaceChange">
          <view class="picker picker--select">
            <text>{{form.place}}</text>
            <text class="picker__arrow">›</text>
          </view>
        </picker>
      </view>
    </view>

    <view class="form-section">
      <view class="form-section__head">
        <view class="form-section__title">联系人</view>
      </view>

      <view class="field-row">
        <view class="field field--half">
          <view class="field__label">来访联系人</view>
          <input
            class="input"
            value="{{form.contactName}}"
            data-field="contactName"
            bindinput="onInput"
            placeholder="姓名"
            placeholder-class="input__placeholder"
          />
        </view>
        <view class="field field--half">
          <view class="field__label">联系电话</view>
          <input
            class="input"
            type="number"
            maxlength="11"
            value="{{form.contactPhone}}"
            data-field="contactPhone"
            bindinput="onInput"
            placeholder="手机号"
            placeholder-class="input__placeholder"
          />
        </view>
      </view>
    </view>

    <view class="form-section">
      <view class="form-section__head">
        <view class="form-section__title">接待人员</view>
      </view>

      <view class="personnel-group">
        <view class="personnel-group__header">
          <view class="personnel-group__title">我方人员</view>
          <view class="personnel-add" data-type="staff" bindtap="onAddPerson">
            <text class="personnel-add__icon">+</text>
            <text class="personnel-add__text">添加</text>
          </view>
        </view>
        <view class="personnel-list">
          <view class="personnel-item" wx:for="{{form.staff}}" wx:key="index">
            <view class="personnel-item__fields">
              <input
                class="input personnel-item__input"
                value="{{item.name}}"
                data-type="staff"
                data-index="{{index}}"
                data-field="name"
                bindinput="onPersonInput"
                placeholder="姓名"
                placeholder-class="input__placeholder"
              />
              <input
                class="input personnel-item__input"
                value="{{item.position}}"
                data-type="staff"
                data-index="{{index}}"
                data-field="position"
                bindinput="onPersonInput"
                placeholder="职位"
                placeholder-class="input__placeholder"
              />
            </view>
            <view class="personnel-item__remove" data-type="staff" data-index="{{index}}" bindtap="onRemovePerson">删除</view>
          </view>
          <view class="personnel-empty" wx:if="{{form.staff.length === 0}}">暂无我方人员，点击上方添加</view>
        </view>
      </view>

      <view class="personnel-group">
        <view class="personnel-group__header">
          <view class="personnel-group__title">对方人员</view>
          <view class="personnel-add" data-type="visitors" bindtap="onAddPerson">
            <text class="personnel-add__icon">+</text>
            <text class="personnel-add__text">添加</text>
          </view>
        </view>
        <view class="personnel-list">
          <view class="personnel-item" wx:for="{{form.visitors}}" wx:key="index">
            <view class="personnel-item__fields">
              <input
                class="input personnel-item__input"
                value="{{item.name}}"
                data-type="visitors"
                data-index="{{index}}"
                data-field="name"
                bindinput="onPersonInput"
                placeholder="姓名"
                placeholder-class="input__placeholder"
              />
              <input
                class="input personnel-item__input"
                value="{{item.position}}"
                data-type="visitors"
                data-index="{{index}}"
                data-field="position"
                bindinput="onPersonInput"
                placeholder="职位"
                placeholder-class="input__placeholder"
              />
            </view>
            <view class="personnel-item__remove" data-type="visitors" data-index="{{index}}" bindtap="onRemovePerson">删除</view>
          </view>
          <view class="personnel-empty" wx:if="{{form.visitors.length === 0}}">暂无对方人员，点击上方添加</view>
        </view>
      </view>
    </view>

    <view class="form-section">
      <view class="form-section__head">
        <view class="form-section__title">会务需求</view>
      </view>

      <view class="chips">
        <button
          class="chip {{item.selected ? 'chip--active' : ''}}"
          wx:for="{{serviceItems}}"
          wx:key="name"
          data-value="{{item.name}}"
          bindtap="onToggleService"
        >
          {{item.name}}
        </button>
      </view>

      <view class="personnel-group" wx:if="{{showVehicleSection}}">
        <view class="personnel-group__header">
          <view class="personnel-group__title">车辆信息</view>
          <view class="personnel-add" bindtap="onAddVehicle">
            <text class="personnel-add__icon">+</text>
            <text class="personnel-add__text">添加</text>
          </view>
        </view>
        <view class="personnel-list">
          <view class="personnel-item" wx:for="{{form.vehicles}}" wx:key="index">
            <view class="personnel-item__fields">
              <input
                class="input personnel-item__input"
                value="{{item.plate}}"
                data-index="{{index}}"
                data-field="plate"
                bindinput="onVehicleInput"
                placeholder="车牌号"
                placeholder-class="input__placeholder"
              />
              <input
                class="input personnel-item__input"
                value="{{item.driverPhone}}"
                data-index="{{index}}"
                data-field="driverPhone"
                bindinput="onVehicleInput"
                placeholder="司机电话"
                placeholder-class="input__placeholder"
                type="number"
                maxlength="11"
              />
            </view>
            <view class="personnel-item__remove" data-index="{{index}}" bindtap="onRemoveVehicle">删除</view>
          </view>
          <view class="personnel-empty" wx:if="{{form.vehicles.length === 0}}">暂无车辆信息，点击上方添加</view>
        </view>
      </view>

      <view class="field">
        <view class="field__label">备注需求</view>
        <textarea
          class="textarea"
          value="{{form.notes}}"
          data-field="notes"
          bindinput="onInput"
          placeholder="如桌签、茶歇、投屏、用餐标准等"
          placeholder-class="input__placeholder"
        />
      </view>
    </view>
  </view>

  <view class="footer">
    <button class="footer__button footer__button--ghost" bindtap="onSaveDraft">暂存</button>
    <button class="footer__button footer__button--primary" loading="{{isSubmitting}}" bindtap="onSubmit">提交申请</button>
  </view>
</view>
